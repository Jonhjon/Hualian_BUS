# 花蓮縣復康巴士預約系統 — 環境變數範例
# 複製此檔案為 .env 並填入實際值

# -----------------------------------------------
# 資料庫（SQL Server）
# -----------------------------------------------
DATABASE_URL="sqlserver://<HOST>:<PORT>;database=<DATABASE>;user=<USER>;password=<PASSWORD>;encrypt=false;trustServerCertificate=true"

# -----------------------------------------------
# JWT 認證
# 產生方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------
JWT_SECRET="<random-32-bytes-hex>"

# -----------------------------------------------
# Email SMTP（密碼重設、Email 驗證）
# 開發期間可留空，系統會以 console 模擬寄信
# Gmail:   HOST=smtp.gmail.com  PORT=587（需設定應用程式密碼）
# Outlook: HOST=smtp-mail.outlook.com  PORT=587
# Ethereal:HOST=smtp.ethereal.email    PORT=587（免費測試信箱）
# -----------------------------------------------
EMAIL_HOST=""
EMAIL_PORT="587"
EMAIL_USER=""
EMAIL_PASS=""

# -----------------------------------------------
# 機器人防護採自製算數驗證碼，使用上方 JWT_SECRET 簽署，無需額外設定
# -----------------------------------------------
